{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": ".bdd-out",
    "rootDir": "."
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", ".bdd-out", ".playwright-bdd"]
}
